# Neon project: iam-check — copy to env.config and fill in values.
# Non-secret configuration. See env.config.example and env.secret.example.

# Neon Auth (branch-scoped — copy from Neon Console → Auth)
NEON_AUTH_BASE_URL=https://ep-example.neonauth.c-2.ap-southeast-1.aws.neon.tech/neondb/auth

NEON_ORG_ID=
NEON_PROJECT_ID=
NEON_BRANCH_ID=

SHARED_ADMIN_EMAIL=operator@example.com
SHARED_ADMIN_NAME=Portal Operator

PREVIEW_CLIENT_EMAIL=preview-client@example.com
PREVIEW_CLIENT_NAME=Preview Client

APP_URL=https://iam-check.vercel.app

# Optional Neon Auth organization display (defaults from APP_URL hostname)
# PORTAL_ORG_SLUG=
# PORTAL_ORG_NAME=iam-check

# Auth shell — set false to rollback to PortalAuthLayout + Neon (SPEC-B / ADR-Auth-UI-001)
GUARDIAN_AUTH_SHELL=true

# Hot Sales Phase 2A RBAC cutover (default off = Phase 1 Admin + sales allowlist).
# Rollback: set false. Dual-read when true (allowlist OR RBAC assignment).
HOT_SALES_RBAC_ENABLED=false

# Local dev: run `node scripts/apply-local-dev-spec-b-env.mjs` → dev-spec-b branch (localhost allowed)
# Preview: production Neon trusts https://*.vercel.app — set GUARDIAN_AUTH_SHELL=true on Vercel Preview

# Playground — LOCAL DEV ONLY (never sync to Vercel production)
PLAYGROUND_ENABLED=false
PLAYGROUND_SURVEY_ID=
PLAYGROUND_ASSIGNMENT_ID=
PLAYGROUND_SURVEY_SLUG=

SHADCN_STUDIO_EMAIL=
EMAIL=
