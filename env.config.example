# Neon project: afenda-lite — copy to env.config and fill in values.
# Single branch policy: production only (br-tiny-hill-ao82jp6f).
# Run: npm run env:neon-production && npm run env:compose

# Neon Auth (production branch)
NEON_AUTH_BASE_URL=https://ep-example.neonauth.c-2.ap-southeast-1.aws.neon.tech/neondb/auth

NEON_ORG_ID=
NEON_PROJECT_ID=young-hat-54755363
NEON_BRANCH_ID=br-tiny-hill-ao82jp6f

SHARED_ADMIN_EMAIL=afenda@admin.com
SHARED_ADMIN_NAME=Afenda Admin

PREVIEW_CLIENT_EMAIL=preview-client@afenda-lite.com
PREVIEW_CLIENT_NAME=Preview Client

APP_URL=https://afenda-lite.vercel.app

# Optional Neon Auth organization display (defaults from APP_URL hostname).
# These are Auth tenant bootstrap labels — not Neon Cloud NEON_ORG_ID.
# Live prod Auth org: slug/name afenda-lite (id in PORTAL_ORGANIZATION_ID).
# PORTAL_ORG_SLUG=afenda-lite
# PORTAL_ORG_NAME=afenda-lite
# Local/multi-org chrome: show organization switcher in AdminCN header
PORTAL_ORG_SWITCHER_ENABLED=false

# Neon Auth tenant org UUID (product) — NOT Neon Cloud NEON_ORG_ID.
# Optional local/ops/E2E fixture for backfill + fft-allowlist (D8).
# PORTAL_ORGANIZATION_ID=
# E2E_ORGANIZATION_ID=

# Auth shell — set false to rollback to PortalAuthLayout + Neon (SPEC-B / ADR-Auth-UI-001)
GUARDIAN_AUTH_SHELL=true

# Feed Farm Trade Phase 2A domain RBAC flag (prod true; local often false).
# When true: FFT domain permissions via assignments (not Phase-1 admin-only path).
# This is NOT soft SQL tenancy — row filters are hard organization_id = org (ADR-002 / 027).
# Rollback domain RBAC: set false → sync:vercel → redeploy.
FFT_RBAC_ENABLED=false

# Feed Farm Trade Phase 2B — operational deposits + pickup ops
FFT_DEPOSIT_ENABLED=false
FFT_PICKUP_OPS_ENABLED=false

# Feed Farm Trade Phase 2C — notifications (Resend). Off until provider keys are set.
FFT_NOTIFICATIONS_ENABLED=false
# FFT_EMAIL_FROM=Afenda <no-reply@nexuscanon.com>
# (bare email also OK: ops@example.com)

# Feed Farm Trade Phase 2D — ERP sync (FFT module only; tenant configures vendor).
# Leave VENDOR/BASE_URL unset until a customer integration pack — syncOptional keys.
FFT_ERP_SYNC_ENABLED=false
# FFT_ERP_VENDOR=http-rest
# FFT_ERP_BASE_URL=https://erp.customer.example

# Playground — LOCAL DEV ONLY (never sync to Vercel production)
PLAYGROUND_ENABLED=false
PLAYGROUND_SURVEY_ID=
PLAYGROUND_ASSIGNMENT_ID=
PLAYGROUND_SURVEY_SLUG=
PLAYGROUND_FFT_EVENT_ID=
PLAYGROUND_FFT_LOCALE=

SHADCN_STUDIO_EMAIL=
EMAIL=
