# Neon project: afenda (snowy-dawn-60990429)
DATABASE_URL=postgresql://...
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.../neondb/auth
NEON_AUTH_COOKIE_SECRET=<openssl rand -base64 32>

# Shared organization admin (run: npm run seed:admin)
SHARED_ADMIN_EMAIL=operator@afenda.cloud
SHARED_ADMIN_PASSWORD=<choose-a-strong-password>
SHARED_ADMIN_NAME=Portal Administrator

# Public app URL for survey invite links (optional; Vercel sets VERCEL_URL automatically)
APP_URL=https://iam-check.vercel.app

# Optional E2E overrides (CI uses SHARED_ADMIN_* by default)
# E2E_OPERATOR_EMAIL=
# E2E_OPERATOR_PASSWORD=
# E2E_SURVEY_SLUG=   # only if not using operator-create → public chain in smoke tests

# shadcn-studio MCP (Pro blocks) — from https://shadcnstudio.com/mcp/onboarding
SHADCN_STUDIO_LICENSE_KEY=<your-shadcn-studio-license-key>
SHADCN_STUDIO_ACCOUNT_EMAIL=<your-shadcn-studio-account-email>
