# Afenda-Lite - copy to `.env.local` and fill in values.
# Schema SSOT: packages/env/src/web.ts + neon-contract.ts (N1) · docs feedback: packages/env/src/docs.ts.
# Product contract: pooler DATABASE_URL; https Neon Auth; cookie secret >=32; approved Neon Cloud ids when set.
# APP_URL hosts: localhost | 127.0.0.1 | afenda-lite.vercel.app (prod must be https://afenda-lite.vercel.app).
# Import: `import { env } from '@afenda/env'` · docs: `import { docsEnv } from '@afenda/env/docs'` — never raw process.env.
# Single branch policy: production only (br-tiny-hill-ao82jp6f).
# Never commit `.env.local`. PLAYGROUND_* stays local-only (never sync to Vercel).

# Required - product boot
# Product runtime requires Neon -pooler host (N1/N2).
# Migrate/ops may temporarily override this same key to an unpooled endpoint in the migrate shell only — do not add DIRECT_* product vars.
DATABASE_URL=postgresql://neondb_owner:[password]@ep-example-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
NEON_AUTH_BASE_URL=https://ep-example.neonauth.c-2.ap-southeast-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=
APP_URL=https://afenda-lite.vercel.app

# Neon Cloud ops (optional for app boot; used by validate:neon-env / CLI)
NEON_ORG_ID=org-fragrant-lake-90358173
NEON_PROJECT_ID=young-hat-54755363
NEON_BRANCH_ID=br-tiny-hill-ao82jp6f
NEON_API_KEY=

# Portal / Auth tenant labels (optional)
# PORTAL_ORG_SLUG=afenda-lite
# PORTAL_ORG_NAME=afenda-lite
PORTAL_ORG_SWITCHER_ENABLED=false
# PORTAL_ORGANIZATION_ID=
# E2E_ORGANIZATION_ID=

GUARDIAN_AUTH_SHELL=true

# RESEND_API_KEY=

# Upstash Redis REST — required on Vercel production for auth rate limits
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Prometheus scrape bearer for GET /api/metrics (min 16 chars). Fail closed when unset → 404.
# METRICS_SCRAPE_TOKEN=

# Vercel AI Gateway — The Machine (`POST /api/ai/chat`). Local fail-closed when unset.
# On Vercel production, OIDC may authenticate Gateway when the key is omitted.
# AI_GATEWAY_API_KEY=
# AI_THE_MACHINE_MODEL=anthropic/claude-sonnet-4.5

# Local developer harness only - never sync to Vercel production
PLAYGROUND_ENABLED=false
# PLAYGROUND_SURVEY_ID=
# PLAYGROUND_ASSIGNMENT_ID=
# PLAYGROUND_SURVEY_SLUG=

# E2E / seed fixtures (optional; local-only passwords — blocked on Vercel production)
SHARED_ADMIN_EMAIL=afenda@admin.com
SHARED_ADMIN_NAME=Afenda Admin
SHARED_ADMIN_PASSWORD=
PREVIEW_CLIENT_EMAIL=preview-client@afenda-lite.com
PREVIEW_CLIENT_NAME=Preview Client
PREVIEW_CLIENT_PASSWORD=
CLIENT_DEFAULT_PASSWORD=
# N13 authenticated factory (unique orgs/users per Playwright worker)
# Plaintext must match the hash-template account password (default template = PREVIEW_CLIENT).
# E2E_FACTORY_PASSWORD=
# E2E_FACTORY_HASH_TEMPLATE_EMAIL=preview-client@afenda-lite.com
# One-off overrides (not factory SSOT — prefer workerTenant)
# E2E_OPERATOR_EMAIL=
# E2E_OPERATOR_PASSWORD=
# E2E_CLIENT_EMAIL=
# E2E_CLIENT_PASSWORD=
# E2E_INVITEE_EMAIL=
# E2E_INVITEE_PASSWORD=
# E2E_SURVEY_SLUG=
# E2E_INVITE_TOKEN=

# Local tooling (optional; never required for product boot)
# SHADCN_STUDIO_EMAIL=
# SHADCN_STUDIO_API_KEY=
# LICENSE_KEY=
# EMAIL=

# @afenda/docs — site origin + feedback (schema: packages/env/src/docs.ts · import { docsEnv } from '@afenda/env/docs')
# DOCS_URL defaults to http://localhost:3001 — set the public https origin on the docs Vercel project (metadataBase / OG)
# DOCS_URL=http://localhost:3001
# Feedback → GitHub Discussions (set after App install on pohlai88/afenda-lite)
# SSOT: docs-V2/docs/feedback.md · og-next.md · deploying.md
# Requires: Discussions enabled · category "Docs Feedback" · GitHub App (Discussions write) installed on this repo
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
