{
  "biome.enabled": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {},
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "explorer.excludeGitIgnore": true,
  "explorer.autoReveal": false,
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,
  "git.decorations.enabled": false,
  "git.autorefresh": false,
  "problems.decorations.enabled": false,
  "scm.diffDecorations": "none",
  "search.followSymlinks": false,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.next-ui": true,
    "**/.next-workflow": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/out": true,
    "**/.artifacts": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.next-ui": true,
    "**/.next-workflow": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/out": true,
    "**/.artifacts": true,
    "**/.git": true,
    "docs/architecture/backend": true,
    "docs/architecture/frontend": true,
    "docs/architecture/system": true,
    "docs/architecture/tech-stack": true,
    "docs/architecture/archive": true,
    "docs/guides/archive": true,
    "**/pnpm-lock.yaml": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.next-ui/**": true,
    "**/.next-workflow/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/test-results/**": true,
    "**/playwright-report/**": true,
    "**/out/**": true,
    "**/.artifacts/**": true,
    "**/.git/**": true,
    "**/pnpm-lock.yaml": true
  },

  "files.associations": {
    "pnpm-lock.yaml": "plaintext",
    "package-lock.json": "plaintext",
    "yarn.lock": "plaintext"
  },

  "yaml.maxItemsComputed": 5000,

  "git.openRepositoryInParentFolders": "never"
}
