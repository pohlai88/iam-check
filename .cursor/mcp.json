{
  "mcpServers": {
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
      "env": {
        "SystemRoot": "C:\\Windows",
        "PROGRAMFILES": "C:\\Program Files"
      }
    },
    "shadcn-studio": {
      "command": "npx",
      "args": ["-y", "shadcn-studio-mcp-1.0.7.tgz"],
      "env": {
        "API_KEY": "${SHADCN_STUDIO_API_KEY}",
        "EMAIL": "${SHADCN_STUDIO_EMAIL}"
      }
    },
    "client-declaration-portal-sb-mcp": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    }
  }
}
