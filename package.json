{
  "name": "afenda-lite",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.33.4"
  },
  "scripts": {
    "preinstall": "node scripts/only-allow-pnpm.mjs",
    "dev": "turbo run dev --filter=@afenda/web",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "postinstall": "node scripts/install-git-hooks.mjs",
    "clean:artifacts": "node -e \"const fs=require('fs'); for (const d of ['.next','.turbo','coverage','test-results','playwright-report','.artifacts']) fs.rmSync(d,{recursive:true,force:true})\"",
    "build": "turbo run build",
    "start": "turbo run start --filter=@afenda/web",
    "build:check": "pnpm run checks && pnpm run build",
    "checks": "node scripts/run-checks.mjs",
    "sync:neon-auth-manifest": "node scripts/collapse-script-unavailable.mjs \"sync:neon-auth-manifest\"",
    "validate:neon-env": "node scripts/validate-neon-env.mjs",
