{
  "name": "client-declaration-portal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "npm run env:compose && next dev",
    "env:compose": "node scripts/compose-env.mjs",
    "env:split": "node scripts/split-env.mjs",
    "build": "next build",
    "start": "next start",
    "build:check": "npm run checks && npm run build",
    "checks": "node scripts/run-checks.mjs",
    "sync:neon-auth-manifest": "node scripts/sync-neon-auth-manifest.mjs",
    "validate:neon-env": "node scripts/validate-neon-env.mjs",
    "audit:neon-auth-production": "node scripts/audit-neon-auth-production.mjs",
    "configure:neon-auth-production": "node scripts/configure-neon-auth-production.mjs",
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:preview-client": "node scripts/seed-preview-client.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:inspect": "node scripts/db-inspect.mjs",
    "db:reset": "node --env-file=.env scripts/db-reset.mjs",
    "db:reset:preview": "node --env-file=.env scripts/db-reset.mjs --keep-preview-client",
    "seed:production": "node --env-file=.env scripts/seed-production.mjs",
    "seed:production:env": "node --env-file=.env scripts/seed-production.mjs --write-env",
    "sync:vercel": "node scripts/sync-vercel-env.mjs production",
    "cleanup:vercel": "node scripts/cleanup-vercel-env.mjs",
    "audit:vercel": "node scripts/audit-vercel-env.mjs production",
    "db:backfill": "node scripts/db-backfill-migrations.mjs",
    "check:copy": "node scripts/check-portal-terminology.mjs",
    "check:nav": "node scripts/check-portal-nav.mjs",
    "check:proxy": "node scripts/check-proxy-routes.mjs",
    "check:db-schema": "node scripts/check-db-schema.mjs",
    "check:playground": "node scripts/check-playground-bindings.mjs",
    "verify:production": "node scripts/verify-production.mjs",
    "verify:vercel-db": "node scripts/validate-vercel-database-url.mjs",
    "icons:generate": "node scripts/generate-brand-icons.mjs",
    "check:brand-icons": "node scripts/check-brand-icons.mjs",
    "validate:brand-icon-bounds": "node scripts/validate-brand-icon-bounds.mjs",
    "test": "playwright test --project all",
    "test:unit": "vitest run --config testing/vitest.config.ts --project unit",
    "test:interaction": "vitest run --config testing/vitest.config.ts --project interaction",
    "test:e2e:smoke": "playwright test --project smoke",
    "test:e2e:journey": "playwright test --project journey",
    "evaluate:ui-matrix": "node scripts/evaluate-ui-matrix.mjs",
    "check:ui-sync": "node --env-file=.env scripts/validate-ui-sync.mjs",
    "studio:init": "npm run env:compose && node scripts/init-shadcn-studio.mjs",
    "studio:mcp": "node scripts/shadcn-studio-mcp.mjs",
    "studio:install-block": "npm run env:compose && node scripts/install-studio-block.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@neondatabase/auth": "^0.4.2-beta",
    "@neondatabase/auth-ui": "^0.2.1-beta",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/functions": "^3.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "mailersend": "^3.0.0",
    "next": "^16.0.10",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "shadcn": "^4.13.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
