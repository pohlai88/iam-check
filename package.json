    "plan:doc-integrity": "node .cursor/skills/afenda-elite-doc-integrity/scripts/remediate-docs.mjs --scope docs/api --mode plan-fix --format json",
    "fix:doc-integrity:safe": "node .cursor/skills/afenda-elite-doc-integrity/scripts/remediate-docs.mjs --scope docs/api --mode apply-safe --apply --format json",
    "openapi:generate": "pnpm exec tsx --tsconfig apps/web/tsconfig.json scripts/generate-openapi.mts",
    "check:openapi": "node scripts/check-openapi.mjs",
    "housekeeping:knip:design-system": "knip --directory packages/design-system",
    "check:nav": "node scripts/collapse-script-unavailable.mjs \"check:nav\"",
    "check:proxy": "node scripts/collapse-script-unavailable.mjs \"check:proxy\"",
    "check:db-schema": "node scripts/collapse-script-unavailable.mjs \"check:db-schema\"",
    "check:playground": "node scripts/collapse-script-unavailable.mjs \"check:playground\"",
    "verify:production": "node scripts/collapse-script-unavailable.mjs \"verify:production\"",
    "check:production:operator": "node scripts/collapse-script-unavailable.mjs \"check:production:operator\"",
    "check:production:join-ui": "node scripts/collapse-script-unavailable.mjs \"check:production:join-ui\"",
    "check:production:post-deploy": "node scripts/collapse-script-unavailable.mjs \"check:production:post-deploy\"",
    "verify:draft-migration": "node scripts/collapse-script-unavailable.mjs \"verify:draft-migration\"",
    "verify:architecture": "pnpm run checks",
    "verify:vercel-db": "node scripts/collapse-script-unavailable.mjs \"verify:vercel-db\"",
    "icons:generate": "node scripts/collapse-script-unavailable.mjs \"icons:generate\"",
    "brand:extract-sharp-owl": "node scripts/collapse-script-unavailable.mjs \"brand:extract-sharp-owl\"",
    "check:brand-icons": "node scripts/collapse-script-unavailable.mjs \"check:brand-icons\"",
    "validate:brand-icon-bounds": "node scripts/collapse-script-unavailable.mjs \"validate:brand-icon-bounds\"",
    "test": "turbo run test",
    "test:unit": "vitest run --config testing/vitest.config.ts",
    "test:interaction": "vitest run --config testing/vitest.config.ts --project interaction --passWithNoTests",
    "test:e2e": "playwright test --project all",
    "check:import-boundaries": "node scripts/collapse-script-unavailable.mjs \"check:import-boundaries\"",
    "check:repo-migration-map": "node scripts/collapse-script-unavailable.mjs \"check:repo-migration-map\"",
    "test:e2e:smoke": "playwright test --project smoke",
    "test:e2e:journey": "playwright test --project journey",
    "evaluate:ui-matrix": "node scripts/collapse-script-unavailable.mjs \"evaluate:ui-matrix\"",
    "check:ui-sync": "node scripts/collapse-script-unavailable.mjs \"check:ui-sync\"",
    "check:fft-ui-registry": "node scripts/collapse-script-unavailable.mjs \"check:fft-ui-registry\"",
    "check:fft-ui-registry:expect-fail": "node scripts/collapse-script-unavailable.mjs \"check:fft-ui-registry:expect-fail\"",
    "generate:fft-ui-registry-admincn": "node scripts/collapse-script-unavailable.mjs \"generate:fft-ui-registry-admincn\"",
    "export:reliance-graph": "node scripts/collapse-script-unavailable.mjs \"export:reliance-graph\"",
    "export:reliance-mapping": "node scripts/collapse-script-unavailable.mjs \"export:reliance-mapping\"",
    "export:route-coverage": "node scripts/collapse-script-unavailable.mjs \"export:route-coverage\"",
    "check:reliance-graph-drift": "node scripts/collapse-script-unavailable.mjs \"check:reliance-graph-drift\"",
    "check:reliance-mapping-drift": "node scripts/collapse-script-unavailable.mjs \"check:reliance-mapping-drift\"",
    "check:reliance-coverage": "node scripts/collapse-script-unavailable.mjs \"check:reliance-coverage\"",
    "check:route-coverage-drift": "node scripts/collapse-script-unavailable.mjs \"check:route-coverage-drift\"",
    "studio:init": "node scripts/collapse-script-unavailable.mjs \"studio:init\"",
    "studio:mcp": "node scripts/collapse-script-unavailable.mjs \"studio:mcp\"",
    "studio:install-block": "node scripts/collapse-script-unavailable.mjs \"studio:install-block\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck test build",
    "lint:root": "biome check ."
  },
  "devDependencies": {
    "@afenda/config": "workspace:*",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@biomejs/biome": "catalog:",
    "@playwright/test": "^1.61.1",
    "@stoplight/json-ref-resolver": "^3.1.6",
    "@stoplight/path": "^1.3.2",
    "@stoplight/spectral-cli": "^6.16.1",
