    "export:route-coverage": "npx tsx scripts/governance/export-route-coverage.mts",
    "check:reliance-graph-drift": "npx tsx scripts/governance/check-reliance-graph-drift.mts",
    "check:reliance-mapping-drift": "npx tsx scripts/governance/check-reliance-mapping-drift.mts",
    "check:reliance-coverage": "npx tsx scripts/governance/check-reliance-coverage.mts",
