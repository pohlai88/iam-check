    "check:module-quality": "node .cursor/skills/afenda-elite-doc-integrity/scripts/audit-docs.mjs --scope docs/modules --format markdown",
    "test:module-pack": "node --test .cursor/skills/afenda-elite-doc-control/scripts/scaffold-module-pack.test.mjs .cursor/skills/afenda-elite-doc-integrity/scripts/module-pack-contract.test.mjs",
    "plan:module-pack": "node .cursor/skills/afenda-elite-doc-control/scripts/scaffold-module-pack.mjs",
    "scaffold:module-pack": "node .cursor/skills/afenda-elite-doc-control/scripts/scaffold-module-pack.mjs",
