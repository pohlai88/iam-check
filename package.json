    "@stoplight/yaml": "^4.3.0",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.3",
    "jsdom": "catalog:",
    "jsonpath-plus": "^10.4.0",
    "knip": "^6.26.0",
    "marked": "^15.0.12",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
