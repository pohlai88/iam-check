{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "root": false,
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next",
    "ultracite/biome/vitest"
  ],
  "files": {
    "includes": [
      "!!**/node_modules",
      "!!**/.git",
      "!!**/.next",
      "!!**/dist",
      "!!**/build",
      "!!**/out",
      "!!**/coverage",
      "!!**/.turbo",
      "!!**/.vercel",
      "!!**/.cache",
      "!!**/.artifacts",
      "!!**/.tmp",
      "!!**/.next-ui",
      "!!**/.next-workflow",
      "!!**/test-results",
      "!!**/playwright-report",
      "!!**/playwright/.cache",
      "!!**/*.{md,mdx}",
      "!!**/docs",
      "!!**/drizzle",
      "!!**/.cursor",
      "!!**/.agents",
      "!!**/_reference",
      "!!**/public",
      "!!**/next-env.d.ts"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/db/migrations/**/*.sql", "**/*.sql"],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    }
  ]
}
