{
	"name": "@afenda/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
