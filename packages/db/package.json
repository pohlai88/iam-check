		"db:generate": "drizzle-kit generate",
		"db:migrate": "node ./scripts/db-migrate-guard.mjs",
		"db:check": "node ./scripts/db-check.mjs"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.0.0",
		"drizzle-orm": "^0.44.2"
	},
	"devDependencies": {
		"@afenda/config": "workspace:*",
		"@types/node": "catalog:",
		"drizzle-kit": "^0.31.4",
		"typescript": "catalog:"
	}
}
