{
	"extends": "@afenda/config/tsconfig/base.json",
	"compilerOptions": {
		"allowJs": true,
		"lib": ["ES2022", "DOM"],
		"paths": {
			"@afenda/config/*": ["./packages/foundation/config/*"]
		}
	},
	"include": ["scripts/**/*.mts", "scripts/**/*.ts", "*.mts", "*.ts"],
	"exclude": [
		"node_modules",
		"apps",
		"packages",
		"_reference",
		".next",
		".turbo",
		"coverage",
		"test-results",
		"playwright-report"
	]
}
