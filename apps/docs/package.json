{
	"name": "@afenda/docs",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Afenda-Lite official documentation site (Fumadocs · OpenAPI consumer for docs-V2)",
	"scripts": {
		"generate:source": "fumadocs-mdx",
		"generate:openapi-docs": "pnpm exec tsx scripts/generate-openapi-docs.mts",
		"lint:links": "pnpm exec tsx scripts/lint-links.mts",
		"list:source-pages": "node --import tsx ./scripts/list-source-pages.mjs",
		"fd": "cli",
		"fd:add": "cli add",
		"fd:add:silent": "pnpm exec tsx scripts/cli-add-silent.mts",
		"fd:customize": "cli customize",
		"fd:tree": "cli tree",
		"test": "vitest run --config ../../testing/vitest.config.ts --project docs",
		"predev": "pnpm generate:source",
		"prebuild": "pnpm generate:source && pnpm generate:openapi-docs",
		"pretypecheck": "pnpm generate:source",
		"dev": "next dev --port 3001",
		"build": "next build",
		"start": "next start --port 3001",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"clean": "node -e \"const fs=require('fs'); for (const d of ['.next','.source','.turbo']) { try { fs.rmSync(d,{recursive:true,force:true,maxRetries:8,retryDelay:100}); } catch (e) { if (e && e.code !== 'ENOENT') throw e; } }\""
	},
	"dependencies": {
		"@afenda/env": "workspace:*",
		"@next/env": "catalog:",
		"@floating-ui/react-dom": "^2.1.9",
		"@fuma-translate/react": "^1.0.2",
		"@radix-ui/react-accordion": "^1.2.16",
		"@radix-ui/react-collapsible": "^1.1.16",
		"@radix-ui/react-tabs": "^1.1.17",
		"class-variance-authority": "^0.7.1",
		"cnfast": "^0.0.8",
		"d3-force": "^3.0.0",
		"feed": "^6.0.0",
		"fumadocs-core": "^16.10.5",
		"fumadocs-mdx": "^15.0.12",
		"fumadocs-openapi": "^11.2.2",
		"fumadocs-typescript": "^5.3.0",
		"fumadocs-ui": "^16.10.5",
		"lucide-react": "catalog:",
		"mdast-util-to-markdown": "^2.1.2",
		"next": "catalog:",
		"octokit": "^5.0.5",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-force-graph-2d": "^1.29.1",
		"react-medium-image-zoom": "^5.4.8",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@afenda/config": "workspace:*",
		"@fumadocs/cli": "^1.4.1",
		"@tailwindcss/postcss": "^4.3.3",
		"@types/d3-force": "^3.0.10",
		"@types/mdx": "^2.0.14",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"next-validate-link": "^1.6.6",
		"tailwindcss": "^4.3.3",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
