engine-strict=true
fund=false
# Workspace install policy (was settings: in pnpm-workspace.yaml —
# SchemaStore schema still rejects that key; .npmrc is the supported home).
auto-install-peers=true
strict-peer-dependencies=false
prefer-frozen-lockfile=true
manage-package-manager-versions=true
save-workspace-protocol=rolling
disallow-workspace-cycles=true
# Hoist platform Biome CLIs so VS Code/Cursor LSP can spawn native binaries (not the node wrapper).
public-hoist-pattern[]=@biomejs/cli-*
