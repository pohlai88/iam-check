# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# pnpm is the sole package manager — do not reintroduce npm/yarn lockfiles
package-lock.json
npm-shrinkwrap.json
yarn.lock

# testing
coverage
test-results/
playwright-report/
blob-report/
playwright/.cache/

# next.js / turbo / package builds
.next/
out/
.turbo/
dist/

# fumadocs-mdx generated collections (apps/docs — also listed in apps/docs/.gitignore)
.source/

# production
/build

# misc
.DS_Store
*.pem
/*.tgz
_reference/
.tmp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor/hooks/**/*.log
.cursor/hooks/.mvp-hook-debug.log
.cursor/hooks/.*-hook-debug.log
.cursor/debug*.log

# env — ARCH-027 / S4.1: `.env.local` is the only Next runtime file
.env*
!.env.example
.env.vercel.*
.env.local.vercel-backup*

# retired compose — do not reintroduce (Contamination ban / Checkpoint D)
/env.config
/env.secret
/env.config.example
/env.secret.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# @afenda/ui-system — package-local scratch docs conflict with ADR-010 / DOC-001
# (controlled docs live under docs/ only). Do not reintroduce.
packages/ui-system/docs/

# Retired husk — do not restore packages/ui or @afenda/ui (ADR-010).
packages/ui/

# Studio DNA Method A installs (bulky) — keep forwarder stubs tracked (M-A1).
# Tracked: apps/web/components.json · shadcn-studio/styles.css · shadcn-studio/lib/utils.ts
apps/web/shadcn-studio/**
!apps/web/shadcn-studio/styles.css
!apps/web/shadcn-studio/lib/
!apps/web/shadcn-studio/lib/utils.ts

